# Stripe (same keys as mongoori-rides – use test keys for local)
# Dashboard: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...

# For success/cancel redirect URLs (optional; defaults to http://localhost:4173 in dev)
# NEXT_PUBLIC_APP_URL=https://your-mongoori-finds-domain.com

# Admin: 주문·배송·환불 관리 페이지 (/admin). 비밀번호로 로그인.
ADMIN_PASSWORD=your-secret-admin-password

# Promo SHIP50: Checkout has "Add promotion code" enabled. In Stripe Dashboard →
# Products → Coupons → Create coupon (e.g. free shipping over $50 or % off), then
# create a Promotion code "SHIP50" for that coupon so it works at checkout.
