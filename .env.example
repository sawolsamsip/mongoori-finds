# Stripe (same keys as mongoori-rides – use test keys for local)
# Dashboard: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Base URL for Stripe success/cancel redirects. If unset, we use the request origin (e.g. 192.168.x.x:4173 or finds.mongoori.com).
# Set this in production: https://finds.mongoori.com
# NEXT_PUBLIC_APP_URL=https://finds.mongoori.com

# Admin: 주문·배송·환불 관리 페이지 (/admin). 비밀번호로 로그인.
ADMIN_PASSWORD=your-secret-admin-password

# Promo SHIP50: Checkout has "Add promotion code" enabled. In Stripe Dashboard →
# Products → Coupons → Create coupon (e.g. free shipping over $50 or % off), then
# create a Promotion code "SHIP50" for that coupon so it works at checkout.

# Stripe Webhook (required for /api/webhook)
# Get from Stripe Dashboard → Developers → Webhooks → Add endpoint
# Endpoint URL: https://finds.mongoori.com/api/webhook
# Events: checkout.session.completed, payment_intent.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (SMTP) — 주문 시 공급업체·관리자에게 자동 발송
# Gmail 예시: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false
# Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Mongoori Finds <your-email@gmail.com>

# 수신자
SUPPLIER_EMAIL=supplier@taptes.com   # TAPTES or EVANNEX 공급업체 이메일
ADMIN_EMAIL=admin@mongoori.com       # 신규 주문 알림 수신 이메일

# MongoDB — 고객 리뷰 저장소 (MongoDB Atlas 권장)
# Atlas 무료 플랜: https://www.mongodb.com/cloud/atlas
# 예시: mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://...
